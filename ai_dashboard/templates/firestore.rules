rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: is the requester the admin email? ──
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email == "antoniojason212@gmail.com";
    }

    // ── Helper: user is authenticated ──
    function isAuth() {
      return request.auth != null;
    }

    // ── Helper: user owns the document ──
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ──────────────────────────────────────────────────────
    // USERS collection
    // Users can read/update their own doc.
    // Admins can read all user docs and update suspended field.
    // ──────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isAuth() && request.auth.uid == uid;
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      // NOTIFICATIONS sub-collection
      // Users read their own; admin can write (to send reminders)
      match /notifications/{notifId} {
        allow read: if isOwner(uid);
        allow write: if isAdmin();
        allow update: if isOwner(uid); // mark read
      }
    }

    // ──────────────────────────────────────────────────────
    // ACTIVITY LOG
    // Only admins can read. Server writes via Admin SDK.
    // ──────────────────────────────────────────────────────
    match /activity_log/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only written server-side via Admin SDK
    }

    // ──────────────────────────────────────────────────────
    // TOOL USAGE
    // Only admins can read. Server-side writes only.
    // ──────────────────────────────────────────────────────
    match /tool_usage/{toolId} {
      allow read: if isAdmin();
      allow write: if false; // Only written server-side via Admin SDK
    }

    // ──────────────────────────────────────────────────────
    // FEEDBACK
    // Authenticated users can create feedback.
    // Only admins can read all feedback.
    // ──────────────────────────────────────────────────────
    match /feedback/{feedbackId} {
      allow create: if isAuth();
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────
    // ANNOUNCEMENTS
    // All authenticated users can read (for notification bell).
    // Only admins can write.
    // ──────────────────────────────────────────────────────
    match /announcements/{announcementId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Deny everything else by default ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
